{
  "_note": "Project-scoped Claude Code config. Versioned (selective gitignore). Hooks live in .claude/hooks/. Lean-code agent in .claude/agents/.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/lean-code-verb-check.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-end-warn.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./setup.sh)",
      "Bash(./dev.sh)",
      "Bash(bash -n dev.sh)",
      "Bash(bun run build)",
      "Bash(mkdir -p *)"
    ]
  }
}
