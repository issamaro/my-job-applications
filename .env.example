# LLM provider: claude | gemini
LLM_PROVIDER=claude

# Anthropic (Claude) — required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google (Gemini) — required when LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SQLite database file (relative to the working directory, or an absolute path)
DATABASE=app.db
